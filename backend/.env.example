# ==========================================
# Turing Arena - Environment Variables
# ==========================================


# --- AI Model APIs (LLMs) ---

# OpenAI API Key (Required for ChatGPT models)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (Required for Gemini models)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# xAI API Key (Required for Grok models)
# Get yours at: https://console.x.ai/
GROK_API_KEY=your_grok_api_key_here

# --- Traditional ML Engines ---

# Stockfish Executable Path (Required for Stockfish adapter)
# Download at: https://stockfishchess.org/download/
# Windows example: C:/path/to/stockfish/stockfish-windows-x86-64-avx2.exe
# Mac/Linux example: /usr/local/bin/stockfish
STOCKFISH_PATH=your_local_stockfish_executable_path_here

# --- Application Settings ---

# Set to 'production' or 'development'
ENVIRONMENT=development

# Optional: Set a custom port for the FastAPI server (default is 8000)
# PORT=8000
